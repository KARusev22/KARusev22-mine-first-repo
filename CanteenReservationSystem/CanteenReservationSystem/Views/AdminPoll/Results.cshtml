@{
    ViewData["FigustaPage"] = true;
    ViewData["FigustaNav"] = "adminPolls";
    
    var totalVotes = 0;
    var maxVotes = -1;
    var topOptionText = "No votes yet";

    foreach (var option in Model.Options)
    {
        var c = option.Votes.Count;
        totalVotes += c;

        if (c > maxVotes)
        {
            maxVotes = c;
            topOptionText = option.OptionText;
        }
    }
}

<h2 class="poll-title">@Model.Question</h2>

<div class="poll-dashboard">
    <div class="left-column">
        <div class="stats-row">
            <div class="stat-card glass">
                <div class="stat-icon">
                    <i class="bi bi-bar-chart-line-fill"></i>
                </div>
                <div class="stat-value">@totalVotes</div>
                <div class="stat-label">Total Votes</div>
            </div>

            <div class="stat-card glass">
                <div class="stat-icon">
                    <i class="bi bi-trophy-fill"></i>
                </div>
                <div class="stat-value">@topOptionText</div>
                <div class="stat-label">Most Voted Option</div>
            </div>

        </div>

        <div class="chart-card glass">
            <canvas id="pollChart"></canvas>
        </div>

    </div>

    <div class="right-column">

        <div class="engagement-card glass">
            <div class="eng-title">
                <i class="bi bi-activity"></i> Engagement Score
            </div>

            <div class="eng-score" id="engScore">0%</div>
            <div class="eng-trend" id="engTrend">↑</div>

            <div class="eng-bar">
                <div class="eng-bar-fill" id="engBarFill"></div>
            </div>

            <div class="eng-level" id="engLevel">Calculating...</div>
        </div>

        <div class="table-card glass">
            <h4 class="table-title">Detailed Breakdown</h4>
            <table class="poll-table">
                <thead>
                    <tr>
                        <th>Option</th>
                        <th>Votes</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var option in Model.Options)
                    {
                        <tr>
                            <td>@option.OptionText</td>
                            <td>@option.Votes.Count</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

    </div>

</div>

<link rel="stylesheet" href="~/css/poll-results.css" />
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script src="~/js/poll-results.js"></script>

<script>
    var labels = [];
    var votes = [];

    @foreach (var option in Model.Options)
    {
        @:labels.push("@option.OptionText");
        @:votes.push(@option.Votes.Count);
    }

    window.pollData = {
        labels: labels,
        votes: votes
    };
</script>