@{
    ViewData["FigustaPage"] = true;
    ViewData["FigustaNav"] = "adminPolls";
}

<link rel="stylesheet" href="~/css/ai.css" />

<div class="ai-wrapper">
    <div class="d-flex justify-content-between align-items-center flex-wrap mb-3" style="gap:12px;">
        <h2 class="mb-0">Create Poll</h2>
        <button type="button" id="ai-poll-btn" class="ai-btn">
            <i class="bi bi-stars"></i> Generate with AI
        </button>
    </div>

    <p class="ai-subtitle">
        Let AI suggest a poll based on your most-ordered dishes and recent customer comments.
        You can edit everything before creating the poll.
    </p>

    @Html.AntiForgeryToken()
    <div id="ai-poll-status" class="mb-3"></div>

    <form method="post">
        <div class="mb-3">
            <label class="form-label">Question</label>
            <input class="form-control" id="poll-question" name="Question" required />
        </div>

        <label class="form-label">Options</label>

        <div id="options">
            <input class="form-control mb-2" name="options" placeholder="Option 1" />
            <input class="form-control mb-2" name="options" placeholder="Option 2" />
        </div>

        <button type="button" class="btn btn-secondary" onclick="addOption()">Add Option</button>
        <button type="submit" class="btn btn-success">Create</button>
    </form>
</div>

<script>
function addOption(value) {
    const div = document.getElementById("options");
    const input = document.createElement("input");
    input.className = "form-control mb-2";
    input.name = "options";
    input.placeholder = "New option";
    if (typeof value === "string") input.value = value;
    div.appendChild(input);
    return input;
}
</script>
<script src="~/js/ai-poll.js"></script>
