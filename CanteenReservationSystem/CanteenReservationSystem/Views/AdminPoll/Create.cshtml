@{
    ViewData["FigustaPage"] = true;
    ViewData["FigustaNav"] = "adminPolls";
}

<h2>Create Poll</h2>

<form method="post">
    <div class="mb-3">
        <label class="form-label">Question</label>
        <input class="form-control" name="Question" required />
    </div>

    <label class="form-label">Options</label>

    <div id="options">
        <input class="form-control mb-2" name="options" placeholder="Option 1" />
        <input class="form-control mb-2" name="options" placeholder="Option 2" />
    </div>

    <button type="button" class="btn btn-secondary" onclick="addOption()">Add Option</button>
    <button type="submit" class="btn btn-success">Create</button>
</form>

<script>
function addOption() {
    const div = document.getElementById("options");
    const input = document.createElement("input");
    input.className = "form-control mb-2";
    input.name = "options";
    input.placeholder = "New option";
    div.appendChild(input);
}
</script>