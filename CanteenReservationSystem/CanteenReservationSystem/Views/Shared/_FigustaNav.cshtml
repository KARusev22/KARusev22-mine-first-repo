@using Microsoft.AspNetCore.Identity
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

@{
    var active = ViewData["FigustaNav"] as string ?? "";
    var user = UserManager.GetUserAsync(User).Result;
    var role = user?.Role;
}

<div class="figusta-nav mx-lg-auto">
    <a class="figusta-nav-link @(active == "menu" ? "is-active" : "")"
       asp-controller="Home" asp-action="Index">Menu</a>

    @if (SignInManager.IsSignedIn(User) && role == "User")
    {
        <a class="figusta-nav-link @(active == "orders" ? "is-active" : "")"
           asp-controller="Orders" asp-action="MyOrders">
            <i class="bi bi-receipt"></i> My Orders
        </a>

        <a class="figusta-nav-link @(active == "stats" ? "is-active" : "")"
           asp-controller="Orders" asp-action="Stats">
            <i class="bi bi-bar-chart"></i> Statistics
        </a>

        <a class="figusta-nav-link @(active == "polls" ? "is-active" : "")"
           asp-controller="Poll" asp-action="Index">
           <i class="bi bi-ui-checks-grid"></i> Polls
        </a>

        <a class="figusta-nav-link @(active == "cart" ? "is-active" : "")"
           asp-controller="Cart" asp-action="Index">
           <i class="bi bi-cart"></i> Cart
        </a>
    }

    <!-- Kitchen -->
    @if (role == "Kitchen")
    {
        <a class="figusta-nav-link @(active == "kitchen" ? "is-active" : "")"
           asp-controller="Home" asp-action="Kitchen">
            <i class="bi bi-cup-hot"></i> Kitchen
        </a>
    }

    <!-- Cashier -->
    @if (role == "Cashier")
    {
        <a class="figusta-nav-link @(active == "cashier" ? "is-active" : "")"
           asp-controller="Home" asp-action="Cashier">
            <i class="bi bi-cash-stack"></i> Cashier
        </a>
    }

    <!-- Admin -->
    @if (role == "Admin")
    {
        <a class="figusta-nav-link @(active == "addDish" ? "is-active" : "")"
           asp-controller="AdminDishes" asp-action="Create">
            <i class="bi bi-plus-circle"></i> Add Dish
        </a>

        <a class="figusta-nav-link @(active == "editDishes" ? "is-active" : "")"
           asp-controller="AdminDishes" asp-action="Index">
            <i class="bi bi-pencil-square"></i> Edit Dishes
        </a>
    }
</div>