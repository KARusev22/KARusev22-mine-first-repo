@{
    ViewData["Title"] = "Admin Dashboard";
    ViewData["FigustaPage"] = true;
    ViewData["FigustaNav"] = "admin";
}

<header class="figusta-page-header">
    <h1 class="figusta-page-title">Admin Dashboard</h1>
    <p class="figusta-page-subtitle">Overview of restaurant performance and analytics</p>
</header>

<div class="figusta-kpi-grid">
    <div class="figusta-kpi-card">
        <div class="figusta-kpi-top">
            <span class="figusta-kpi-icon"><i class="bi bi-currency-dollar"></i></span>
            <span class="figusta-kpi-badge">+12.5%</span>
        </div>
        <p class="figusta-kpi-value">$94,500</p>
        <p class="figusta-kpi-label">Total Revenue</p>
    </div>
    <div class="figusta-kpi-card">
        <div class="figusta-kpi-top">
            <span class="figusta-kpi-icon"><i class="bi bi-graph-up-arrow"></i></span>
            <span class="figusta-kpi-badge">+8.2%</span>
        </div>
        <p class="figusta-kpi-value">1,247</p>
        <p class="figusta-kpi-label">Total Orders</p>
    </div>
    <div class="figusta-kpi-card">
        <div class="figusta-kpi-top">
            <span class="figusta-kpi-icon"><i class="bi bi-people"></i></span>
            <span class="figusta-kpi-badge">+15.3%</span>
        </div>
        <p class="figusta-kpi-value">856</p>
        <p class="figusta-kpi-label">Active Customers</p>
    </div>
    <div class="figusta-kpi-card">
        <div class="figusta-kpi-top">
            <span class="figusta-kpi-icon"><i class="bi bi-star-fill"></i></span>
            <span class="figusta-kpi-badge">+0.3</span>
        </div>
        <p class="figusta-kpi-value">4.6</p>
        <p class="figusta-kpi-label">Avg. Rating</p>
    </div>
</div>

<div class="figusta-admin-charts">
    <div class="figusta-panel-card figusta-chart-panel">
        <h2 class="figusta-chart-title">Revenue Overview</h2>
        <div class="figusta-chart-wrap">
            <canvas id="figusta-revenue-chart" aria-label="Revenue overview line chart"></canvas>
        </div>
    </div>
    <div class="figusta-panel-card figusta-chart-panel">
        <h2 class="figusta-chart-title">Peak Days</h2>
        <div class="figusta-chart-wrap">
            <canvas id="figusta-peak-days-chart" aria-label="Peak days bar chart"></canvas>
        </div>
    </div>
</div>

<div class="figusta-admin-bottom">
    <div class="figusta-panel-card">
        <h2 class="figusta-chart-title">Popular Meals</h2>
        <ol class="figusta-popular-meals">
            <li class="figusta-popular-row">
                <span class="figusta-popular-rank">1</span>
                <div class="figusta-popular-info">
                    <span class="figusta-popular-name">Beef Burger</span>
                    <span class="figusta-popular-orders">248 orders</span>
                </div>
                <div class="figusta-popular-revenue">
                    <span class="figusta-popular-amount">$4,711</span>
                    <span class="figusta-popular-revenue-label">revenue</span>
                </div>
            </li>
            <li class="figusta-popular-row">
                <span class="figusta-popular-rank">2</span>
                <div class="figusta-popular-info">
                    <span class="figusta-popular-name">Margherita Pizza</span>
                    <span class="figusta-popular-orders">215 orders</span>
                </div>
                <div class="figusta-popular-revenue">
                    <span class="figusta-popular-amount">$3,653</span>
                    <span class="figusta-popular-revenue-label">revenue</span>
                </div>
            </li>
            <li class="figusta-popular-row">
                <span class="figusta-popular-rank">3</span>
                <div class="figusta-popular-info">
                    <span class="figusta-popular-name">Grilled Salmon</span>
                    <span class="figusta-popular-orders">189 orders</span>
                </div>
                <div class="figusta-popular-revenue">
                    <span class="figusta-popular-amount">$4,721</span>
                    <span class="figusta-popular-revenue-label">revenue</span>
                </div>
            </li>
            <li class="figusta-popular-row">
                <span class="figusta-popular-rank">4</span>
                <div class="figusta-popular-info">
                    <span class="figusta-popular-name">Sushi Platter</span>
                    <span class="figusta-popular-orders">156 orders</span>
                </div>
                <div class="figusta-popular-revenue">
                    <span class="figusta-popular-amount">$4,520</span>
                    <span class="figusta-popular-revenue-label">revenue</span>
                </div>
            </li>
            <li class="figusta-popular-row">
                <span class="figusta-popular-rank">5</span>
                <div class="figusta-popular-info">
                    <span class="figusta-popular-name">Chicken Pasta</span>
                    <span class="figusta-popular-orders">142 orders</span>
                </div>
                <div class="figusta-popular-revenue">
                    <span class="figusta-popular-amount">$2,839</span>
                    <span class="figusta-popular-revenue-label">revenue</span>
                </div>
            </li>
        </ol>
    </div>

    <div class="figusta-panel-card figusta-satisfaction-panel">
        <h2 class="figusta-chart-title">Customer Satisfaction</h2>
        <div class="figusta-chart-wrap figusta-donut-wrap">
            <canvas id="figusta-satisfaction-chart" aria-label="Customer satisfaction donut chart"></canvas>
        </div>
        <ul class="figusta-satisfaction-legend">
            <li><span class="figusta-legend-swatch figusta-legend-excellent"></span> Excellent <strong>45%</strong></li>
            <li><span class="figusta-legend-swatch figusta-legend-good"></span> Good <strong>35%</strong></li>
            <li><span class="figusta-legend-swatch figusta-legend-average"></span> Average <strong>15%</strong></li>
            <li><span class="figusta-legend-swatch figusta-legend-poor"></span> Poor <strong>5%</strong></li>
        </ul>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
    <script src="~/js/figusta-admin.js" asp-append-version="true"></script>
}
