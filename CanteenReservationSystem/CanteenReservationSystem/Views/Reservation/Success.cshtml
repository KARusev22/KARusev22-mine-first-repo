@model CanteenReservationSystem.Models.Orders

@{
    ViewData["Title"] = "Reservation Successful";
}

<link rel="stylesheet" href="~/css/reservation-success.css" />

<div class="success-container">

    <h1 class="success-title">
        <i class="bi bi-check-circle-fill"></i>
        Reservation Successful
    </h1>

    <p class="success-message">
        Your reservation has been created successfully.
    </p>

    <div class="reservation-box">

        <h2 class="section-title">
            <i class="bi bi-receipt"></i>
            Reservation Details
        </h2>

        <p class="detail-line">
            <i class="bi bi-key icon"></i>
            <strong>Reservation Code:</strong>
            <span class="reservation-code">@Model.UniqueCode</span>
        </p>

        <p class="detail-line">
            <i class="bi bi-calendar-event icon"></i>
            <strong>For Date:</strong> @Model.TargetDate.ToString("yyyy-MM-dd")
        </p>

        <p class="detail-line">
            <i class="bi bi-person icon"></i>
            <strong>Customer:</strong> @Model.User.FullName
        </p>

        <h3 class="section-title">
            <i class="bi bi-cart-check"></i>
            Ordered Items
        </h3>

        <table class="reservation-table">
            <thead>
                <tr>
                    <th>Dish</th>
                    <th>Quantity</th>
                    <th>Price (euro)</th>
                    <th>Note</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.OrderDetails)
                {
                    <tr>
                        <td>@item.Dish.DishName</td>
                        <td>@item.Quantity</td>
                        <td>@item.Dish.Price</td>
                        <td>@item.Note</td>
                    </tr>
                }
            </tbody>
        </table>

        <p class="total-line">
            <i class="bi bi-cash-coin icon"></i>
            <strong>Total Price:</strong> @Model.TotalPrice euro
        </p>

        <a href="/Cart" class="back-btn">
            <i class="bi bi-arrow-left-circle"></i>
            Back to Cart
        </a>

    </div>

</div>