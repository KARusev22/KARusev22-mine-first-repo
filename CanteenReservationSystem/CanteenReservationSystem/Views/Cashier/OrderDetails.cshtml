@model Orders

@{
    ViewData["Title"] = "Order Details";
}

<link rel="stylesheet" href="~/css/cashier.css" />
<link rel="stylesheet" href="~/css/ai.css" />

@Html.AntiForgeryToken()

<div class="cashier-container">
    <h2 class="cashier-title">Order Details</h2>

    @if (ViewBag.Error != null)
    {
        <div class="alert alert-danger">@ViewBag.Error</div>
    }

    @if (ViewBag.Success != null)
    {
        <div class="alert alert-success">@ViewBag.Success</div>
    }
    
    <div class="cashier-details-box">
        <p><strong>Code:</strong> @Model.UniqueCode</p>
        <p><strong>Customer:</strong> @Model.User.UserName</p>
        <p><strong>Total Price:</strong> @Model.TotalPrice.ToString("0.00") euro.</p>

        <h4>Items:</h4>
        <ul class="cashier-items">
            @foreach (var item in Model.OrderDetails)
            {
                <li>@item.Dish.DishName — @item.Quantity pcs</li>
            }
        </ul>
    </div>

    <!-- AI handover assistant: loads on demand, never blocks the counter flow -->
    <div class="ai-card mt-3">
        <div class="d-flex justify-content-between align-items-center flex-wrap" style="gap:12px;">
            <h4 class="ai-title mb-0">
                <span class="ai-badge"><i class="bi bi-stars"></i> AI</span>
                Pickup Assistant
            </h4>
            <button id="ai-cashier-btn" class="ai-btn" data-code="@Model.UniqueCode">
                <i class="bi bi-chat-left-text"></i> Summarize for handover
            </button>
        </div>
        <div id="ai-cashier-result" class="mt-2"></div>
    </div>

    @if (ViewBag.Success == null && Model.Status == "Completed")
    {
        <div class="alert alert-info mt-3">This order has already been taken.</div>
    }

    @if (ViewBag.Success == null && Model.Status != "Completed")
    {
        <form method="post" asp-action="CompleteOrder">
            <input type="hidden" name="orderId" value="@Model.Id" />
            <button type="submit" class="cashier-btn">Mark as Taken</button>
        </form>
    }
</div>

<script src="~/js/ai-cashier.js"></script>