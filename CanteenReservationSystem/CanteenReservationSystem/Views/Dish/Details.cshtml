@model CanteenReservationSystem.Models.Dish

@{
    ViewData["Title"] = Model.DishName;
    ViewData["FigustaPage"] = true;
}

<div class="figusta-main">

    <div class="figusta-page-header">
        <h1 class="figusta-page-title">@Model.DishName</h1>
        <p class="figusta-page-subtitle">@Model.Category?.CategoryName</p>
    </div>

    <div class="figusta-panel-card figusta-dish-details-card">

        <img src="@Model.ImageUrl"
             alt="@Model.DishName"
             class="figusta-dish-details-image" />

        <h2 class="figusta-dish-title">@Model.DishName</h2>

        <p class="figusta-dish-category">
            Category: @Model.Category?.CategoryName
        </p>

        <p class="figusta-dish-price">
            @Model.Price.ToString("0.00") euro
        </p>

        @if (!string.IsNullOrWhiteSpace(Model.Characteristics))
        {
            <p class="figusta-dish-characteristics">
                <strong>Characteristics:</strong> @Model.Characteristics
            </p>
        }

        @if (!string.IsNullOrWhiteSpace(Model.Description))
        {
            <p class="figusta-dish-description">
                @Html.Raw(Model.Description)
            </p>
        }
        
        @if (ViewBag.AvailableDays != null && ((List<DayOfWeek>)ViewBag.AvailableDays).Any())
        {
            <p><strong>Available this month:</strong>
                @string.Join(", ", ((List<DayOfWeek>)ViewBag.AvailableDays))
            </p>
        }
        else
        {
            <p><strong>Not available this month</strong></p>
        }

        <!-- NUTRITION -->
        @if (Model.Nutrition != null)
        {
            <div class="figusta-panel-card figusta-nutrition-card">
                <div class="figusta-panel-heading">
                    <span class="figusta-panel-icon figusta-panel-icon-green">
                        <i class="bi bi-heart-pulse"></i>
                    </span>
                    <h2>Nutrition</h2>
                </div>

                <ul class="figusta-ingredient-list">
                    <li class="figusta-ingredient-row"><span>Calories</span><span>@Model.Nutrition.Calories kcal</span></li>
                    <li class="figusta-ingredient-row"><span>Protein</span><span>@Model.Nutrition.Protein g</span></li>
                    <li class="figusta-ingredient-row"><span>Fats</span><span>@Model.Nutrition.Fats g</span></li>
                    <li class="figusta-ingredient-row"><span>Carbohydrates</span><span>@Model.Nutrition.Carbohydrates g</span></li>
                    <li class="figusta-ingredient-row"><span>Fiber</span><span>@Model.Nutrition.Fiber g</span></li>
                    <li class="figusta-ingredient-row"><span>Weight</span><span>@Model.Nutrition.WeightGrams g</span></li>
                </ul>
            </div>
        }

        <!-- INGREDIENTS -->
        @if (Model.DishIngredients?.Any() == true)
        {
            <div class="figusta-panel-card figusta-ingredients-card">
                <div class="figusta-panel-heading">
                    <span class="figusta-panel-icon figusta-panel-icon-green">
                        <i class="bi bi-list-ul"></i>
                    </span>
                    <h2>Ingredients</h2>
                </div>

                <ul class="figusta-ingredient-list">
                    @foreach (var ing in Model.DishIngredients)
                    {
                        <li class="figusta-ingredient-row">
                            <span>@ing.Ingredient.IngredientName</span>
                            <span>@ing.GramsPerPortion g</span>
                        </li>
                    }
                </ul>
            </div>
        }

        <!-- ALLERGENS -->
        @if (Model.DishAllergens?.Any() == true)
        {
            <div class="figusta-panel-card figusta-allergens-card">
                <div class="figusta-panel-heading">
                    <span class="figusta-panel-icon figusta-panel-icon-green">
                        <i class="bi bi-exclamation-triangle"></i>
                    </span>
                    <h2>Allergens</h2>
                </div>

                <ul class="figusta-ingredient-list">
                    @foreach (var al in Model.DishAllergens)
                    {
                        <li class="figusta-ingredient-row">
                            <span>@al.Allergen.AllergenName</span>

                            @if (!string.IsNullOrWhiteSpace(al.Allergen.IconUrl))
                            {
                                <img src="@al.Allergen.IconUrl"
                                     alt="@al.Allergen.AllergenName"
                                     class="figusta-allergen-icon" />
                            }
                        </li>
                    }
                </ul>
            </div>
        }

        <form asp-controller="Cart" asp-action="Add" method="post">
            <input type="hidden" name="dishId" value="@Model.Id" />
            <input type="hidden" name="quantity" value="1" />
        @if (User.IsInRole("User"))
            {
                <button type="submit" class="figusta-btn-primary">
                    Add to Cart
                </button>
            }
        </form>

    </div>

</div>