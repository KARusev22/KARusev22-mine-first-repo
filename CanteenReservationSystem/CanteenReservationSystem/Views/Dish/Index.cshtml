@model IEnumerable<CanteenReservationSystem.Models.Dish>

@{
    ViewData["Title"] = "Menu";
    ViewData["FigustaPage"] = true;
    ViewData["FigustaNav"] = "menu";

    var categories = Model
        .Select(x => x.Category)
        .Where(x => x != null)
        .Distinct()
        .OrderBy(x => x.CategoryName)
        .ToList();
}

<section class="figusta-filter-bar">
    <div class="figusta-filter-group">
        <label for="figusta-search-input" class="figusta-filter-label">Search dishes</label>
        <input id="figusta-search-input"
               class="figusta-filter-input"
               type="search"
               placeholder="Search by name..."
               autocomplete="off"
               aria-label="Search dishes by name" />
    </div>

    <div class="figusta-filter-group">
        <label for="figusta-sort-select" class="visually-hidden">Sort by price</label>
        <select id="figusta-sort-select" class="figusta-sort-select" aria-label="Sort dishes by price">
            <option value="asc" selected>Price: Low to High</option>
            <option value="desc">Price: High to Low</option>
        </select>
    </div>

    <div class="figusta-filter-group">
        <label for="figusta-category-filter" class="visually-hidden">Filter by category</label>
        <select id="figusta-category-filter" class="figusta-filter-select" aria-label="Filter by category">
            <option value="all" selected>All</option>

            @foreach (var category in categories)
            {
                <option value="@category.CategoryName.ToLower()">
                    @category.CategoryName
                </option>
            }
        </select>
    </div>
</section>

<div class="figusta-empty-state visually-hidden" id="figusta-empty-state" role="status" aria-live="polite">
    No dishes match your search. Try a different name or clear the filters.
</div>

<div class="figusta-menu-grid" id="figusta-menu-grid">

    @foreach (var dish in Model)
    {
        <article class="figusta-dish-card"
                 data-category="@dish.Category.CategoryName.ToLower()"
                 data-name="@dish.DishName.ToLower()"
                 data-price="@dish.Price">

            <img class="figusta-dish-image"
                 src="@dish.ImageUrl"
                 alt="@dish.DishName"
                 loading="lazy" />

            <div class="figusta-dish-body">
                <h2 class="figusta-dish-title">@dish.DishName</h2>
                <p class="figusta-dish-category">@dish.Category.CategoryName</p>
                <p class="figusta-dish-price">@dish.Price.ToString("0.00") euro</p>

                <a asp-controller="Dish"
                   asp-action="Details"
                   asp-route-id="@dish.Id"
                   class="figusta-btn-primary"
                   style="display:inline-block;margin-top:0.75rem;">
                    View Details
                </a>
            </div>

        </article>
    }
</div>

@section Scripts {
    <script src="~/js/menu.js"></script>
}