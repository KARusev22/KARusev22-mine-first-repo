@model IEnumerable<CanteenReservationSystem.Models.Dish>

<link rel="stylesheet" href="~/css/admin-dishes.css" />

<h1 class="mb-4">Manage Dishes</h1>

<p>
    <a asp-controller="AdminDishes" asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-circle"></i> Create Dish
    </a>
</p>

<table class="table table-hover align-middle">
    <thead class="table-light">
        <tr>
            <th>Image</th>
            <th>Name</th>
            <th>Category</th>
            <th>Price (€)</th>
            <th class="text-end">Actions</th>
        </tr>
    </thead>
    <tbody>
    @foreach (var dish in Model)
    {
        <tr>
            <td>
                @if (!string.IsNullOrWhiteSpace(dish.ImageUrl))
                {
                    <img src="@dish.ImageUrl" class="admin-thumb" />
                }
            </td>
            <td>@dish.DishName</td>
            <td>@dish.Category?.CategoryName</td>
            <td>@dish.Price.ToString("0.00")</td>
            <td class="text-end">
                <a asp-controller="AdminDishes" asp-action="Edit" asp-route-id="@dish.Id"
                   class="btn btn-sm btn-warning me-1">
                    <i class="bi bi-pencil-square"></i>
                </a>

                <button class="btn btn-sm btn-danger delete-btn"
                        data-id="@dish.Id"
                        data-name="@dish.DishName"
                        data-bs-toggle="modal"
                        data-bs-target="#deleteModal">
                    <i class="bi bi-trash"></i>
                </button>
            </td>
        </tr>
    }
    </tbody>
</table>

<div class="modal fade" id="deleteModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">

      <div class="modal-header">
        <h5 class="modal-title">
            <i class="bi bi-exclamation-triangle text-danger"></i> Confirm Delete
        </h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>

      <div class="modal-body">
        <p>Are you sure you want to delete <strong id="dishName"></strong>?</p>
      </div>

      <div class="modal-footer">
          <form id="deleteForm" method="post">
              @Html.AntiForgeryToken()
              <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                  Cancel
              </button>
              <button type="submit" class="btn btn-danger">
                  <i class="bi bi-trash"></i> Delete
              </button>
          </form>
      </div>

    </div>
  </div>
</div>

<script src="~/js/admin-dishes.js"></script>