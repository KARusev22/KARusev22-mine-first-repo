@using System.Security.Claims
@model IEnumerable<Polls>

@{
    ViewData["FigustaPage"] = true;
    ViewData["FigustaNav"] = "polls";
}

<link rel="stylesheet" href="~/css/poll-user.css" />
<script src="~/js/poll-user.js"></script>

<h2 class="poll-page-title">Active Polls</h2>

<div class="poll-scroll-wrapper">

    <button class="scroll-btn left" onclick="scrollPolls(-1)">
        <i class="bi bi-chevron-left"></i>
    </button>

    <div class="poll-scroll" id="pollScroll">

        @foreach (var poll in Model)
        {
            var userId = User.Claims.FirstOrDefault(c => c.Type == ClaimTypes.NameIdentifier)?.Value;
            var options = poll.Options ?? new List<PollOptions>();
            bool hasVoted = options.Any(o => (o.Votes ?? new List<Votes>())
                .Any(v => v.UserId == userId));

            <div class="poll-card glass" data-poll-id="@poll.Id">

                <div class="poll-question">@poll.Question</div>

                @if (!hasVoted)
                {
                    <div class="poll-options">
                        @foreach (var option in options)
                        {
                            <label class="poll-option">
                                <input type="radio" name="option-@poll.Id" value="@option.Id" />
                                <span>@option.OptionText</span>
                            </label>
                        }
                    </div>

                    <button class="poll-vote-btn" onclick="submitVote(@poll.Id)">Vote</button>
                }
                else
                {
                    <div class="poll-voted-label">You already voted</div>
                    <a class="poll-results-btn" href="/AdminPoll/Results/@poll.Id">View Results</a>
                }

            </div>
        }

    </div>

    <button class="scroll-btn right" onclick="scrollPolls(1)">
        <i class="bi bi-chevron-right"></i>
    </button>

</div>