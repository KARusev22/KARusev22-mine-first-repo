@model CanteenReservationSystem.Models.ViewModels.KitchenViewModel

@{
    ViewData["FigustaPage"] = true;
}

<link rel="stylesheet" href="~/css/kitchen.css" />

<div class="kitchen-layout">
    <aside class="ingredients-card">
        <h4 class="section-title">Required Ingredients</h4>

        <div class="ingredients-list">
            @foreach (var ing in Model.Ingredients)
            {
                <div class="ingredient-row">
                    <span>@ing.IngredientName</span>
                    <span class="qty">@ing.TotalQuantity @ing.Unit</span>
                </div>
            }
        </div>
    </aside>

    <main class="kitchen-content">

        <div class="header-block">
            <h2>Kitchen Dashboard – @Model.SelectedDate.ToString("dd.MM.yyyy")</h2>

            <form method="get" class="date-form">
                <input type="date" name="date"
                       value="@Model.SelectedDate.ToString("yyyy-MM-dd")"
                       class="form-control date-picker" />
                <button class="btn-load">Load</button>
            </form>
        </div>

        <section class="glass-card mb-4">
            <h4 class="section-title">Portions by Category</h4>

            <div class="category-grid">
                @foreach (var c in Model.Categories)
                {
                    <div class="category-card">
                        <div class="cat-name">@c.CategoryName</div>
                        <div class="cat-count">@c.TotalPortions portions</div>
                    </div>
                }
            </div>
        </section>

        <section class="glass-card">
            <h4 class="section-title">Dishes Overview</h4>

            @foreach (var d in Model.Dishes)
            {
                <div class="dish-card">

                    <div class="dish-header">
                        <span class="dish-name">@d.DishName</span>
                        <span class="badge bg-success">@d.TotalPortions portions</span>
                    </div>

                    @if (d.Notes.Any(n => !string.IsNullOrWhiteSpace(n.Note)))
                    {
                        <div class="notes-list">
                            @foreach (var n in d.Notes.Where(n => !string.IsNullOrWhiteSpace(n.Note)))
                            {
                                <div class="note-item">
                                    <span class="note-qty">@n.Quantity×</span>
                                    <span class="note-text">@n.Note</span>
                                </div>
                            }
                        </div>
                    }
                </div>
            }
        </section>

    </main>

</div>

<script src="~/js/kitchen.js"></script>