@model CanteenReservationSystem.Models.ViewModels.UserStatsViewModel

@{
    Layout = "_Layout";
    ViewData["FigustaPage"] = true;
}

@section Styles {
    <link rel="stylesheet" href="~/css/stats.css" />
}

<div class="container mt-4">

    <h2 class="stats-header">Your Activity Overview</h2>

    <!-- Hidden values -->
    <input type="hidden" id="TakenOrdersValue" value="@Model.TakenOrders" />
    <input type="hidden" id="NotTakenOrdersValue" value="@Model.NotTakenOrders" />
    <input type="hidden" id="Top3Days" value='@System.Text.Json.JsonSerializer.Serialize(Model.Top3Days)' />
    <input type="hidden" id="Top3Categories" value='@System.Text.Json.JsonSerializer.Serialize(Model.Top3Categories)' />

    <div class="row">

        <div class="col-md-4 mb-3">
            <div class="card p-3 text-center stats-card">
                <i class="bi bi-bag-check-fill text-primary stats-icon"></i>
                <h5>Total Orders</h5>
                <p class="display-6 fw-bold">@Model.TotalOrders</p>
            </div>
        </div>

        <div class="col-md-4 mb-3">
            <div class="card p-3 text-center stats-card">
                <i class="bi bi-cash-stack text-warning stats-icon"></i>
                <h5>Total Spent</h5>
                <p class="display-6 fw-bold">@Model.TotalSpent.ToString("0.00") EUR</p>
            </div>
        </div>

        <div class="col-md-4 mb-3">
            <div class="card p-3 text-center stats-card">
                <i class="bi bi-star-fill text-success stats-icon"></i>
                <h5>Most Ordered Dish</h5>
                <p class="fs-4 fw-semibold">@Model.MostOrderedDish</p>
            </div>
        </div>

    </div>

    <div class="row mt-4">

        <!-- PIE -->
        <div class="col-md-4 mb-4">
            <div class="card p-3 stats-card">
                <h5 class="chart-title"><i class="bi bi-pie-chart-fill"></i> Taken vs Not Taken</h5>
                <div class="chart-container-small">
                    <canvas id="statusChart"></canvas>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-4">
            <div class="card p-3 stats-card">
                <h5 class="chart-title"><i class="bi bi-calendar-week"></i> Top 3 Days</h5>
                <div class="chart-container-medium">
                    <canvas id="topDaysChart"></canvas>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-4">
            <div class="card p-3 stats-card">
                <h5 class="chart-title"><i class="bi bi-list-ul"></i> Top 3 Categories</h5>
                <div class="chart-container-medium">
                    <canvas id="topCategoriesChart"></canvas>
                </div>
            </div>
        </div>

    </div>

</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="~/js/stats.js"></script>
}