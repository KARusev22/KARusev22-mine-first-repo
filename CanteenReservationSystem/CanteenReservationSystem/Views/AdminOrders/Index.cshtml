@model List<CanteenReservationSystem.Models.ViewModels.OrderViewModel>

@{
    ViewData["Title"] = "Admin Orders";
    ViewData["FigustaPage"] = true;
    ViewData["FigustaNav"] = "adminOrders";
}

@section Styles {
    <link rel="stylesheet" href="~/css/admin-orders.css" />
}

@section Scripts {
    <script src="~/js/admin-orders.js"></script>
}

<div class="container py-4">
    <h2 class="mb-4 text-center fw-bold">Admin Orders</h2>

    <div class="row g-4">
        @foreach (var o in Model)
        {
            <div class="col-md-4">
                <div class="order-card glass-card p-4 rounded-4 shadow-lg">

                    <!-- STATUS -->
                    <span class="badge status-badge @o.Status.ToLower()">
                        @o.Status
                    </span>

                    <h5 class="fw-bold mb-3 order-title">
                        <i class="bi bi-receipt-cutoff me-2"></i> @o.Code
                    </h5>

                    <p class="mb-1">
                        <i class="bi bi-person-circle me-2"></i>
                        @ViewBag.UserNames[o.Id]
                    </p>

                    <p class="mb-1">
                        <i class="bi bi-calendar-event me-2"></i>
                        @o.CreatedOn.ToString("dd MMM yyyy", System.Globalization.CultureInfo.InvariantCulture)
                    </p>

                    <p class="mb-1">
                        <i class="bi bi-flag me-2"></i>
                        For: @o.TargetDate.ToString("dd MMM yyyy", System.Globalization.CultureInfo.InvariantCulture)
                    </p>

                    <p class="mb-1">
                        <i class="bi bi-cash-coin me-2"></i>
                        @o.TotalPrice euro
                    </p>

                    <div class="mt-3 text-end">
                        <a href="/AdminOrders/Details/@o.Id" class="btn dotted-btn rounded-pill px-4">
                            View Details <i class="bi bi-arrow-right-circle ms-2"></i>
                        </a>
                    </div>

                </div>
            </div>
        }
    </div>
</div>